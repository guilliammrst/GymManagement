@inherits LayoutComponentBase

<MudThemeProvider Theme="customTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="modern-layout">
    <LoginRedirect />
    
    <!-- Main App Container -->
    <div class="app-container">
        <!-- Sidebar -->
        <MudDrawer @bind-Open="@sidebarOpen" 
                   Elevation="2" 
                   Variant="DrawerVariant.Mini" 
                   OpenMiniOnHover="true"
                   ClipMode="DrawerClipMode.Always"
                   Color="Color.Surface"
                   Class="sidebar">
            <div class="sidebar-header">
                <div class="logo-container">
                    <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Class="logo-icon" />
                    <MudText Typo="Typo.h6" Class="logo-text">GymManager</MudText>
                </div>
            </div>
            
            <MudDivider />
            
            <MudNavMenu>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                    Dashboard
                </MudNavLink>
                <MudNavLink Href="/users" Icon="@Icons.Material.Filled.People">
                    Users
                </MudNavLink>
                <MudNavLink Href="/clubs" Icon="@Icons.Material.Filled.Business">
                    Clubs
                </MudNavLink>
                <MudNavLink Href="/membership-plans" Icon="@Icons.Material.Filled.CardMembership">
                    Membership Plans
                </MudNavLink>
                <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Assessment">
                    Reports
                </MudNavLink>
                <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                    Settings
                </MudNavLink>
            </MudNavMenu>
        </MudDrawer>
        
        <!-- Main Content Area -->
        <div class="main-content">
            <!-- Top Header -->
            <MudAppBar Elevation="2" Class="top-header">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                               Color="Color.Inherit" 
                               Edge="Edge.Start" 
                               OnClick="@ToggleSidebar" />
                
                <MudSpacer />
                
                <!-- Search Bar -->
                <MudTextField @bind-Value="searchQuery" 
                              Placeholder="Search..." 
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              AdornmentColor="Color.Secondary"
                              Class="search-bar"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                
                <MudSpacer />
                
                <!-- User Profile Menu -->
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" 
                         Color="Color.Inherit" 
                         Direction="Direction.Bottom" 
                         OffsetX="true">
                    <MudMenuItem OnClick="@ViewProfile">
                        <div class="menu-item-content">
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                            <MudText>Profile</MudText>
                        </div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="@ShowSettings">
                        <div class="menu-item-content">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" />
                            <MudText>Settings</MudText>
                        </div>
                    </MudMenuItem>
                    <MudDivider />
                    <LogoutDisplay />
                </MudMenu>
            </MudAppBar>
            
            <!-- Page Content -->
            <div class="page-content">
                @Body
            </div>
        </div>
    </div>
</div>

<style>
    .modern-layout {
        height: 100vh;
        overflow: hidden;
    }
    
    .app-container {
        display: flex;
        height: 100%;
    }
    
    .sidebar {
        width: var(--sidebar-width);
        background: var(--background-card);
        border-right: 1px solid var(--border-color);
    }
    
    .sidebar-header {
        padding: var(--spacing-lg);
        border-bottom: 1px solid var(--border-color);
    }
    
    .logo-container {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }
    
    .logo-icon {
        color: var(--primary-color);
        font-size: 2rem;
    }
    
    .logo-text {
        font-weight: 600;
        color: var(--text-primary);
    }
    
    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    
    .top-header {
        background: var(--background-card);
        color: var(--text-primary);
        border-bottom: 1px solid var(--border-color);
        height: var(--header-height);
    }
    
    .search-bar {
        max-width: 400px;
        margin: 0 var(--spacing-lg);
    }
    
    .menu-item-content {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }
    
    .page-content {
        flex: 1;
        overflow: auto;
        padding: var(--content-padding);
        background: var(--background-secondary);
    }
    
    /* Responsive Design */
    @media (max-width: 768px) {
        .sidebar {
            transform: translateX(-100%);
            transition: transform var(--transition-normal);
        }
        
        .sidebar.open {
            transform: translateX(0);
        }
        
        .search-bar {
            display: none;
        }
    }
</style>

