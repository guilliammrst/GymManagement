@inherits LayoutComponentBase
@using GymManagement.Presentation.WebApp.Services
@inject IAuthManager AuthManager
@inject AuthenticatedUser AuthenticatedUser
@inject NavigationManager Navigation

<div class="app-container">
    <header class="navbar">
        <div class="navbar-brand">
            <a href="/" class="brand-link">
                <span class="brand-icon">🏋️</span>
                <span class="brand-text">GymManager</span>
            </a>
        </div>
        
        <nav class="navbar-nav">
            <a href="/" class="nav-link @(IsActive("/") ? "active" : "")">
                <span class="nav-icon">🏠</span>
                <span class="nav-text">HOME</span>
            </a>
            <a href="/users" class="nav-link @(IsActive("/users") ? "active" : "")">
                <span class="nav-icon">👥</span>
                <span class="nav-text">USERS</span>
            </a>
            <a href="/clubs" class="nav-link @(IsActive("/clubs") ? "active" : "")">
                <span class="nav-icon">🏢</span>
                <span class="nav-text">CLUBS</span>
            </a>
            <a href="/membership-plans" class="nav-link @(IsActive("/membership-plans") ? "active" : "")">
                <span class="nav-icon">📋</span>
                <span class="nav-text">PLANS</span>
            </a>
            <a href="/membership-plans" class="nav-link @(IsActive("/membership-plans") ? "active" : "")">
                <span class="nav-icon">📋</span>
                <span class="nav-text">PLANS</span>
            </a>

->

            <a href="/membership-plans" class="nav-link @(IsActive("/membership-plans") ? "active" : "")">
                <span class="nav-icon">📋</span>
                <span class="nav-text">PLANS</span>
            </a>
            <a href="/test-pure" class="nav-link @(IsActive("/test-pure") ? "active" : "")">
                <span class="nav-icon">🧪</span>
                <span class="nav-text">TEST</span>
            </a>
        </nav>
        
        <div class="navbar-user">
            @if (!string.IsNullOrEmpty(AuthenticatedUser.Token))
            {
                <div class="user-menu">
                    <span class="user-name">@AuthenticatedUser.Email</span>
                    <button class="logout-btn" @onclick="Logout">Logout</button>
                </div>
            }
            else
            {
                <a href="/login" class="login-btn">Login</a>
            }
        </div>
    </header>
    
    <main class="main-content">
        @Body
    </main>
    
    <!-- Custom Modal Container -->
    <div id="modal-container" class="modal-container" style="display: none;">
        <div class="modal-backdrop" @onclick="CloseModal"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modal-title"></h3>
                <button class="modal-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body" id="modal-body"></div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Annuler</button>
                <button class="btn btn-primary" id="modal-confirm" @onclick="ConfirmModal">OK</button>
            </div>
        </div>
    </div>
    
    <!-- Custom Notification Container -->
    <div id="notification-container" class="notification-container"></div>
</div>

@code {
    private bool IsActive(string href)
    {
        return Navigation.Uri.EndsWith(href, StringComparison.OrdinalIgnoreCase);
    }
    
    private void Logout()
    {
        AuthManager.Logout();
    }
    
    private void CloseModal()
    {
        // Cette fonctionnalité sera implémentée avec JavaScript
    }
    
    private void ConfirmModal()
    {
        // Cette méthode sera surchargée par les composants qui l'utilisent
        CloseModal();
    }
} 