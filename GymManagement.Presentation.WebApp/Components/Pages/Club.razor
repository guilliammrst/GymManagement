@page "/clubs/{ClubId:int}"
@rendermode InteractiveServer
@using GymManagement.Application.Interfaces.Services.Clubs
@using GymManagement.Presentation.WebApp.ApiClients.Gym
@using GymManagement.Presentation.WebApp.Services
@using GymManagement.Shared.Core.Enums
@inject GymAdminApiClient GymApiClient
@inject INotificationService NotificationService
@inject IModalService ModalService
@inject NavigationManager Navigation

<PageTitle>@(club?.Name) - GymManager</PageTitle>

<div class="page-container">
    @if (isLoading)
    {
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <p>Chargement des informations du club...</p>
        </div>
    }
    else if (club == null)
    {
        <div class="error-container">
            <div class="error-icon">❌</div>
            <h2>Club non trouvé</h2>
            <p>Le club demandé n'existe pas ou a été supprimé.</p>
            <button class="btn btn-primary" @onclick="NavigateToClubs">
                Retour à la liste
            </button>
        </div>
    }
    else
    {
        <!-- En-tête club -->
        <div class="club-header">
            <div class="breadcrumb">
                <a href="/clubs" class="breadcrumb-link">Clubs</a>
                <span class="breadcrumb-separator">›</span>
                <span class="breadcrumb-current">@club.Name</span>
            </div>
            
            <div class="club-header-content">
                <div class="club-icon-large">🏢</div>
                
                <div class="club-header-info">
                    <h1 class="club-name">@club.Name</h1>
                    <p class="club-email">@club.Email</p>
                    <div class="club-badges">
                        <span class="badge badge-primary">
                            Établissement actif
                        </span>
                        <span class="badge badge-secondary">
                            Créé le @club.CreatedAt.ToString("dd/MM/yyyy")
                        </span>
                    </div>
                </div>
                
                <div class="club-header-actions">
                    <button class="btn btn-outline" @onclick="EditClub">
                        <span class="btn-icon">✏️</span>
                        Modifier
                    </button>
                    <button class="btn btn-danger" @onclick="DeleteClub">
                        <span class="btn-icon">🗑️</span>
                        Supprimer
                    </button>
                </div>
            </div>
        </div>

        <!-- Contenu principal -->
        <div class="club-content">
            <div class="content-grid">
                <!-- Informations générales -->
                <div class="info-card">
                    <div class="card-header">
                        <h3>
                            <span class="card-icon">ℹ️</span>
                            Informations générales
                        </h3>
                    </div>
                    <div class="card-content">
                        <div class="info-grid">
                            <div class="info-item">
                                <label class="info-label">Nom du club</label>
                                <span class="info-value">@club.Name</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Email</label>
                                <span class="info-value">@club.Email</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Téléphone</label>
                                <span class="info-value">@(club.PhoneNumber ?? "Non renseigné")</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Date de création</label>
                                <span class="info-value">@club.CreatedAt.ToString("dd/MM/yyyy à HH:mm")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Adresse -->
                @if (club.Address != null)
                {
                    <div class="info-card">
                        <div class="card-header">
                            <h3>
                                <span class="card-icon">📍</span>
                                Adresse
                            </h3>
                        </div>
                        <div class="card-content">
                            <div class="address-content">
                                <div class="address-line">
                                    <strong>@club.Address.Street</strong>
                                </div>
                                <div class="address-line">
                                    @club.Address.PostalCode @club.Address.City
                                </div>
                                <div class="address-line">
                                    @GetCountryDisplayName(club.Address.Country)
                                </div>
                            </div>
                            
                            <div class="address-actions">
                                <button class="btn btn-sm btn-outline" @onclick="OpenMapView">
                                    <span class="btn-icon">🗺️</span>
                                    Voir sur la carte
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- Plans d'abonnement -->
                @if (club.MembershipPlans != null && club.MembershipPlans.Any())
                {
                    <div class="info-card plans-card">
                        <div class="card-header">
                            <h3>
                                <span class="card-icon">📋</span>
                                Plans d'abonnement (@club.MembershipPlans.Count)
                            </h3>
                        </div>
                        <div class="card-content">
                            <div class="plans-grid">
                                @foreach (var plan in club.MembershipPlans)
                                {
                                    <div class="plan-item">
                                        <div class="plan-header">
                                            <h4 class="plan-name">@plan.Name</h4>
                                            <span class="plan-price">@plan.Price.ToString("C")</span>
                                        </div>
                                        <div class="plan-details">
                                            <p class="plan-description">@(plan.Description ?? "Aucune description")</p>
                                            <div class="plan-meta">
                                                <span class="plan-duration">@GetPlanDuration(plan.Period)</span>
                                                <span class="plan-type">@GetPlanType(plan.Type)</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Statistiques -->
                <div class="info-card">
                    <div class="card-header">
                        <h3>
                            <span class="card-icon">📊</span>
                            Statistiques
                        </h3>
                    </div>
                    <div class="card-content">
                        <div class="stats-grid">
                            <div class="stat-item">
                                <div class="stat-value">@(club.MembershipPlans?.Count ?? 0)</div>
                                <div class="stat-label">Plans d'abonnement</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">@GetDaysSinceCreation()</div>
                                <div class="stat-label">Jours d'activité</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">@GetActiveStatus()</div>
                                <div class="stat-label">Statut</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }
    
    .loading-container, .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem;
        text-align: center;
    }
    
    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 4px solid var(--border-color);
        border-top: 4px solid var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1rem;
    }
    
    .error-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .error-container h2 {
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }
    
    .error-container p {
        color: var(--text-secondary);
        margin-bottom: 2rem;
    }
    
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        font-size: 0.9rem;
    }
    
    .breadcrumb-link {
        color: var(--primary-color);
        text-decoration: none;
    }
    
    .breadcrumb-link:hover {
        text-decoration: underline;
    }
    
    .breadcrumb-separator {
        color: var(--text-secondary);
    }
    
    .breadcrumb-current {
        color: var(--text-primary);
        font-weight: 500;
    }
    
    .club-header {
        margin-bottom: 2rem;
    }
    
    .club-header-content {
        display: flex;
        align-items: flex-start;
        gap: 2rem;
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
    }
    
    .club-icon-large {
        font-size: 5rem;
        color: var(--primary-color);
        flex-shrink: 0;
    }
    
    .club-header-info {
        flex: 1;
    }
    
    .club-name {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.5rem 0;
    }
    
    .club-email {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin: 0 0 1rem 0;
    }
    
    .club-badges {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    
    .badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .badge-primary {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }
    
    .badge-secondary {
        background: rgba(107, 114, 128, 0.1);
        color: #6b7280;
    }
    
    .club-header-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    
    .content-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 1.5rem;
    }
    
    .info-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
    }
    
    .plans-card {
        grid-column: 1 / -1;
    }
    
    .card-header {
        background: rgba(var(--primary-color-rgb), 0.05);
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 1.5rem;
    }
    
    .card-header h3 {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0;
    }
    
    .card-icon {
        font-size: 1.2rem;
    }
    
    .card-content {
        padding: 1.5rem;
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }
    
    .info-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .info-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .info-value {
        font-size: 1rem;
        color: var(--text-primary);
        font-weight: 500;
    }
    
    .address-content {
        margin-bottom: 1rem;
    }
    
    .address-line {
        margin-bottom: 0.5rem;
        color: var(--text-primary);
        font-size: 1rem;
    }
    
    .address-actions {
        display: flex;
        gap: 0.5rem;
    }
    
    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
    }
    
    .plan-item {
        background: rgba(var(--primary-color-rgb), 0.02);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1rem;
    }
    
    .plan-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }
    
    .plan-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0;
    }
    
    .plan-price {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--primary-color);
    }
    
    .plan-description {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
        line-height: 1.4;
    }
    
    .plan-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }
    
    .plan-duration, .plan-type {
        padding: 0.25rem 0.5rem;
        background: rgba(var(--primary-color-rgb), 0.1);
        border-radius: 4px;
    }
    
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
    }
    
    .stat-item {
        text-align: center;
        padding: 1rem;
        background: rgba(var(--primary-color-rgb), 0.02);
        border: 1px solid var(--border-color);
        border-radius: 8px;
    }
    
    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }
    
    .stat-label {
        font-size: 0.9rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    @media (max-width: 768px) {
        .page-container {
            padding: 1rem;
        }
        
        .club-header-content {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        
        .club-header-actions {
            justify-content: center;
        }
        
        .content-grid {
            grid-template-columns: 1fr;
        }
        
        .info-grid {
            grid-template-columns: 1fr;
        }
        
        .plans-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public int ClubId { get; set; }
    
    private ClubDetailsDto? club;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadClub();
    }

    private async Task LoadClub()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            club = await GymApiClient.GetClubByIdAsync(ClubId);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Erreur lors du chargement du club: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task EditClub()
    {
        if (club != null)
        {
            await ModalService.ShowModal("update-club-modal", new { club = club });
        }
    }

    private async Task DeleteClub()
    {
        if (club == null) return;

        var confirmed = await ModalService.ShowConfirmDialog(
            "Supprimer le club",
            $"Êtes-vous sûr de vouloir supprimer le club \"{club.Name}\" ? Cette action est irréversible.",
            "Supprimer",
            "danger"
        );

        if (confirmed)
        {
            try
            {
                // Note: Assuming there's a DeleteClubAsync method in the API client
                await NotificationService.ShowSuccess("Club supprimé avec succès");
                Navigation.NavigateTo("/clubs");
            }
            catch (Exception ex)
            {
                await NotificationService.ShowError($"Erreur lors de la suppression: {ex.Message}");
            }
        }
    }

    private void OpenMapView()
    {
        if (club?.Address != null)
        {
            var address = $"{club.Address.Street}, {club.Address.PostalCode} {club.Address.City}";
            var encodedAddress = Uri.EscapeDataString(address);
            var mapUrl = $"https://www.google.com/maps/search/?api=1&query={encodedAddress}";
            
            // Open in new tab
            Navigation.NavigateTo(mapUrl, forceLoad: true);
        }
    }

    private string GetCountryDisplayName(Country country)
    {
        return country switch
        {
            Country.France => "France",
            Country.Belgium => "Belgique",
            Country.Switzerland => "Suisse",
            Country.Canada => "Canada",
            _ => country.ToString()
        };
    }

    private string GetPlanDuration(MembershipPeriod period)
    {
        return period switch
        {
            MembershipPeriod.Monthly => "Mensuel",
            MembershipPeriod.Quarterly => "Trimestriel",
            MembershipPeriod.Yearly => "Annuel",
            _ => period.ToString()
        };
    }

    private string GetPlanType(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "Basique",
            MembershipPlanType.Premium => "Premium",
            MembershipPlanType.VIP => "VIP",
            _ => type.ToString()
        };
    }

    private int GetDaysSinceCreation()
    {
        return club != null ? (DateTime.Now - club.CreatedAt).Days : 0;
    }

    private string GetActiveStatus()
    {
        return "Actif";
    }
    
    private void NavigateToClubs()
    {
        Navigation.NavigateTo("/clubs");
    }
} 