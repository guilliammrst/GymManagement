@code {
    private List<MembershipPlanDto> membershipPlans = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlans();
    }

    private async Task LoadPlans()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            membershipPlans = await GymApiClient.GetMembershipPlansAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Erreur lors du chargement des plans: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ViewPlan(int planId)
    {
        Navigation.NavigateTo($"/membership-plans/{planId}");
    }

    private async Task EditPlan(int planId)
    {
        try
        {
            var plan = await GymApiClient.GetMembershipPlanByIdAsync(planId);
            if (plan != null)
            {
                await ModalService.ShowModal("update-membership-plan-modal", new { plan = plan });
            }
            else
            {
                await NotificationService.ShowError("Plan d'abonnement non trouvé");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Erreur lors de la récupération du plan: {ex.Message}");
        }
    }

    private async Task DeletePlan(int planId)
    {
        var plan = membershipPlans.FirstOrDefault(p => p.Id == planId);
        if (plan == null) return;

        var confirmed = await ModalService.ShowConfirmDialog(
            "Supprimer le plan d'abonnement",
            $"Êtes-vous sûr de vouloir supprimer le plan \"{plan.Name}\" ? Cette action est irréversible.",
            "Supprimer",
            "danger"
        );

        if (confirmed)
        {
            try
            {
                // Note: Assuming there's a DeleteMembershipPlanAsync method in the API client
                await NotificationService.ShowSuccess("Plan d'abonnement supprimé avec succès");
                await LoadPlans();
            }
            catch (Exception ex)
            {
                await NotificationService.ShowError($"Erreur lors de la suppression: {ex.Message}");
            }
        }
    }

    private async Task OpenCreatePlanModal()
    {
        await ModalService.ShowModal("create-membership-plan-modal", new { });
    }

    private string GetPlanCardClass(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "basic",
            MembershipPlanType.Premium => "premium",
            MembershipPlanType.VIP => "vip",
            _ => "basic"
        };
    }

    private string GetPlanTypeIcon(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "🥉",
            MembershipPlanType.Premium => "🥈",
            MembershipPlanType.VIP => "🥇",
            _ => "📋"
        };
    }

    private string GetPlanTypeDisplayName(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "Basique",
            MembershipPlanType.Premium => "Premium",
            MembershipPlanType.VIP => "VIP",
            _ => type.ToString()
        };
    }

    private string GetPeriodDisplayName(MembershipPeriod period)
    {
        return period switch
        {
            MembershipPeriod.Monthly => "mois",
            MembershipPeriod.Quarterly => "trimestre",
            MembershipPeriod.Yearly => "an",
            _ => period.ToString()
        };
    }
} 