@page "/membership-plans"
@rendermode InteractiveServer
@using GymManagement.Application.Interfaces.Services.MembershipPlans
@using GymManagement.Presentation.WebApp.ApiClients.Gym
@using GymManagement.Presentation.WebApp.Services
@using GymManagement.Shared.Core.Enums
@inject GymAdminApiClient GymApiClient
@inject INotificationService NotificationService
@inject IModalService ModalService
@inject NavigationManager Navigation

<PageTitle>Gestion des Plans d'Abonnement - GymManager</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div class="page-title">
            <h1>
                <span class="page-icon">📋</span>
                Plans d'Abonnement
            </h1>
            <p>Gérez les différents types d'abonnements de votre salle</p>
        </div>
        <div class="page-actions">
            <button class="btn btn-primary" @onclick="OpenCreatePlanModal">
                <span class="btn-icon">➕</span>
                Nouveau Plan
            </button>
        </div>
    </div>

    <div class="page-content">
        <!-- Actions rapides -->
        <div class="quick-actions">
            <button class="btn btn-outline" @onclick="LoadPlans">
                <span class="btn-icon">🔄</span>
                Actualiser
            </button>
        </div>

        <!-- Liste des plans -->
        @if (isLoading)
        {
            <div class="loading-container">
                <div class="loading-spinner"></div>
                <p>Chargement des plans d'abonnement...</p>
            </div>
        }
        else if (membershipPlans.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">📋</div>
                <h3>Aucun plan d'abonnement</h3>
                <p>Créez votre premier plan d'abonnement pour commencer</p>
                <button class="btn btn-primary" @onclick="OpenCreatePlanModal">
                    <span class="btn-icon">➕</span>
                    Créer un plan
                </button>
            </div>
        }
        else
        {
            <div class="plans-grid">
                @foreach (var plan in membershipPlans)
                {
                    <div class="plan-card @GetPlanCardClass(plan.Type)">
                        <div class="plan-header">
                            <div class="plan-type-badge">
                                @GetPlanTypeIcon(plan.Type)
                            </div>
                            <h3 class="plan-name">@plan.Name</h3>
                            <div class="plan-price">
                                <span class="price-amount">@plan.Price.ToString("C")</span>
                                <span class="price-period">/ @GetPeriodDisplayName(plan.Period)</span>
                            </div>
                        </div>
                        
                        <div class="plan-content">
                            <div class="plan-description">
                                @if (!string.IsNullOrEmpty(plan.Description))
                                {
                                    <p>@plan.Description</p>
                                }
                                else
                                {
                                    <p class="no-description">Aucune description disponible</p>
                                }
                            </div>
                            
                            <div class="plan-details">
                                <div class="detail-item">
                                    <span class="detail-label">Type</span>
                                    <span class="detail-value">@GetPlanTypeDisplayName(plan.Type)</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Période</span>
                                    <span class="detail-value">@GetPeriodDisplayName(plan.Period)</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Créé le</span>
                                    <span class="detail-value">@plan.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="plan-actions">
                            <button class="btn btn-sm btn-outline" 
                                    @onclick="() => ViewPlan(plan.Id)"
                                    title="Voir les détails">
                                <span class="btn-icon">👁️</span>
                            </button>
                            <button class="btn btn-sm btn-outline" 
                                    @onclick="() => EditPlan(plan.Id)"
                                    title="Modifier">
                                <span class="btn-icon">✏️</span>
                            </button>
                            <button class="btn btn-sm btn-danger" 
                                    @onclick="() => DeletePlan(plan.Id)"
                                    title="Supprimer">
                                <span class="btn-icon">🗑️</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

