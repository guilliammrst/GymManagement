@page "/membership-plans"
@rendermode InteractiveServer
@attribute [StreamRendering(true)]
@attribute [OutputCache(Duration = 5)]

<PageTitle>Membership Plans - Gym Management</PageTitle>

<div class="membership-plans-container animate-fade-in">
	<!-- Header Section -->
	<div class="page-header">
		<div class="header-content">
			<div class="header-title">
				<MudText Typo="Typo.h4">
					<MudIcon Icon="@Icons.Material.Filled.CardMembership" Class="header-icon" />
					Membership Plans
				</MudText>
				<MudText Typo="Typo.body1" Color="Color.Secondary">
					Manage subscription plans and pricing for your gym
				</MudText>
			</div>
			<div class="header-actions">
				<MudButton Variant="Variant.Filled"
						 Color="Color.Primary"
						 StartIcon="@Icons.Material.Filled.Add"
						 OnClick="OpenCreatePlanDialog"
						 Class="create-button">
					Create New Plan
				</MudButton>
			</div>
		</div>
	</div>

	<!-- Content Section -->
	@if (isLoading)
	{
		<div class="loading-container">
			<MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
			<MudText Typo="Typo.body1" Color="Color.Secondary">Loading membership plans...</MudText>
		</div>
	}
	else if (membershipPlans == null || membershipPlans.Count == 0)
	{
		<div class="empty-state">
			<MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Class="empty-icon" />
			<MudText Typo="Typo.h6" Color="Color.Secondary">No membership plans found</MudText>
			<MudText Typo="Typo.body2" Color="Color.Secondary">
				Create your first membership plan to get started
			</MudText>
			<MudButton Variant="Variant.Filled"
					   Color="Color.Primary"
					   StartIcon="@Icons.Material.Filled.Add"
					   OnClick="OpenCreatePlanDialog"
					   Class="empty-action-button">
				Create First Plan
			</MudButton>
		</div>
	}
	else
	{
		<!-- Membership Plans Grid -->
		<div class="plans-grid">
			@foreach (var plan in membershipPlans)
			{
				<MudCard Class="@GetPlanCardClass(plan)">
					@if (IsPopularPlan(plan))
					{
						<div class="popular-badge">
							<MudChip T="string" Color="Color.Warning" Size="Size.Small">
								<MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
								Most Popular
							</MudChip>
						</div>
					}
					
					<MudCardContent Class="plan-content">
						<!-- Plan Header -->
						<div class="plan-header">
							<div class="plan-icon">
								<MudIcon Icon="@GetPlanIcon(plan)" Size="Size.Large" />
							</div>
							<MudText Typo="Typo.h5" Class="plan-name">@plan.Name</MudText>
							<MudChip T="string" Color="Color.Warning" Size="Size.Small">
								@plan.Type
							</MudChip>
							<MudText Typo="Typo.body2" Color="Color.Secondary" Class="plan-description">
								@plan.Description
							</MudText>
						</div>

						<!-- Pricing -->
						<div class="plan-pricing">
							<div class="price-container">
								<MudText Typo="Typo.h3" Class="price-amount">
									$@plan.Price
								</MudText>
								<MudText Typo="Typo.body2" Color="Color.Secondary" Class="price-period">
									/ @GetPeriodText(plan.Period)
								</MudText>
							</div>
							@if (plan.Price > 0)
							{
								<MudText Typo="Typo.caption" Color="Color.Secondary" Class="price-note">
									Billed @GetBillingText(plan.Period)
								</MudText>
							}
						</div>

						<!-- Features -->
						<div class="plan-features">
							<MudList T="string" Dense="true">
								@foreach (var feature in GetPlanFeatures(plan))
								{
									<MudListItem T="string" Icon="@Icons.Material.Filled.Check" 
												 IconColor="Color.Success"
												 Class="feature-item">
										<MudText Typo="Typo.body2">@feature</MudText>
									</MudListItem>
								}
							</MudList>
						</div>

						<!-- Stats -->
						<div class="plan-stats">
							<div class="stat-item">
								<MudText Typo="Typo.caption" Color="Color.Secondary">Subscribers</MudText>
								<MudText Typo="Typo.body1">@GetSubscriberCount(plan)</MudText>
							</div>
							<div class="stat-item">
								<MudText Typo="Typo.caption" Color="Color.Secondary">Revenue</MudText>
								<MudText Typo="Typo.body1">$@GetMonthlyRevenue(plan)</MudText>
							</div>
						</div>
					</MudCardContent>

					<MudCardActions Class="plan-actions">
						<MudButton Variant="@GetActionButtonVariant(plan)"
								   Color="@GetActionButtonColor(plan)"
								   FullWidth="true"
								   Class="subscribe-button">
							@GetActionButtonText(plan)
						</MudButton>
						
						<div class="action-menu">
							<MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default">
								<MudMenuItem OnClick="@(() => EditPlan(plan.Id))">
									<div class="menu-item-content">
										<MudIcon Icon="@Icons.Material.Filled.Edit" />
										<span>Edit Plan</span>
									</div>
								</MudMenuItem>
								<MudMenuItem OnClick="@(() => ViewSubscribers(plan.Id))">
									<div class="menu-item-content">
										<MudIcon Icon="@Icons.Material.Filled.People" />
										<span>View Subscribers</span>
									</div>
								</MudMenuItem>
								<MudDivider />
								<MudMenuItem OnClick="@(() => DeletePlan(plan.Id))">
									<div class="menu-item-content">
										<MudIcon Icon="@Icons.Material.Filled.Delete" />
										<span>Delete Plan</span>
									</div>
								</MudMenuItem>
							</MudMenu>
						</div>
					</MudCardActions>
				</MudCard>
			}
		</div>

		<!-- Summary Statistics -->
		<MudCard Class="summary-card">
			<MudCardContent>
				<MudText Typo="Typo.h6" GutterBottom="true">
					<MudIcon Icon="@Icons.Material.Filled.Analytics" Class="summary-icon" />
					Plans Overview
				</MudText>
				
				<div class="summary-stats">
					<div class="summary-stat">
						<div class="stat-value">@membershipPlans.Count</div>
						<div class="stat-label">Total Plans</div>
					</div>
					<div class="summary-stat">
						<div class="stat-value">@GetTotalSubscribers()</div>
						<div class="stat-label">Total Subscribers</div>
					</div>
					<div class="summary-stat">
						<div class="stat-value">$@GetTotalRevenue()</div>
						<div class="stat-label">Monthly Revenue</div>
					</div>
					<div class="summary-stat">
						<div class="stat-value">$@GetAveragePrice().ToString("F0")</div>
						<div class="stat-label">Average Price</div>
					</div>
				</div>
			</MudCardContent>
		</MudCard>
	}
</div>

<style>
	.membership-plans-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--content-padding);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xl);
	}

	.page-header {
		background: var(--background-card);
		border-radius: var(--radius-lg);
		padding: var(--spacing-lg);
		box-shadow: var(--shadow-sm);
		border: 1px solid var(--border-color);
	}

	.header-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-md);
	}

	.header-title {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xs);
	}

	.header-icon {
		margin-right: var(--spacing-sm);
		color: var(--primary-color);
	}

	.create-button {
		height: 40px;
		border-radius: var(--radius-lg);
		font-weight: 600;
	}

	.loading-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-2xl);
		gap: var(--spacing-lg);
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
	}

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-2xl);
		gap: var(--spacing-lg);
		text-align: center;
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
	}

	.empty-icon {
		font-size: 4rem;
		color: var(--text-muted);
	}

	.empty-action-button {
		margin-top: var(--spacing-md);
		height: 44px;
		border-radius: var(--radius-lg);
		font-weight: 600;
	}

	.plans-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: var(--spacing-xl);
		margin-bottom: var(--spacing-xl);
	}

	.plan-card {
		background: var(--background-card);
		border-radius: var(--radius-xl);
		border: 2px solid var(--border-color);
		transition: all var(--transition-normal);
		position: relative;
		overflow: hidden;
	}

	.plan-card.popular {
		border-color: var(--primary-color);
		box-shadow: var(--shadow-lg);
		transform: scale(1.02);
	}

	.plan-card.premium {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
	}

	.plan-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-xl);
	}

	.popular-badge {
		position: absolute;
		top: var(--spacing-md);
		right: var(--spacing-md);
		z-index: 1;
	}

	.plan-content {
		padding: var(--spacing-xl);
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.plan-header {
		text-align: center;
		margin-bottom: var(--spacing-xl);
	}

	.plan-icon {
		margin-bottom: var(--spacing-md);
		color: var(--primary-color);
	}

	.plan-name {
		font-weight: 700;
		margin-bottom: var(--spacing-sm);
	}

	.plan-description {
		line-height: 1.5;
	}

	.plan-pricing {
		text-align: center;
		margin-bottom: var(--spacing-xl);
		padding: var(--spacing-lg) 0;
		border-top: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
	}

	.price-container {
		display: flex;
		align-items: baseline;
		justify-content: center;
		gap: var(--spacing-xs);
		margin-bottom: var(--spacing-sm);
	}

	.price-amount {
		font-weight: 800;
		color: var(--primary-color);
	}

	.price-period {
		font-weight: 500;
	}

	.price-note {
		opacity: 0.8;
	}

	.plan-features {
		flex: 1;
		margin-bottom: var(--spacing-lg);
	}

	.feature-item {
		padding: var(--spacing-xs) 0;
		border-radius: var(--radius-sm);
	}

	.plan-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-md);
		padding: var(--spacing-md);
		background: var(--background-tertiary);
		border-radius: var(--radius-md);
		margin-bottom: var(--spacing-lg);
	}

	.stat-item {
		text-align: center;
	}

	.plan-actions {
		padding: var(--spacing-lg);
		display: flex;
		gap: var(--spacing-md);
		align-items: center;
	}

	.subscribe-button {
		height: 44px;
		border-radius: var(--radius-lg);
		font-weight: 600;
		text-transform: none;
	}

	.action-menu {
		flex-shrink: 0;
	}

	.menu-item-content {
		display: flex;
		align-items: center;
		gap: var(--spacing-sm);
	}

	.summary-card {
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
		box-shadow: var(--shadow-sm);
	}

	.summary-icon {
		margin-right: var(--spacing-sm);
		color: var(--primary-color);
	}

	.summary-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
		gap: var(--spacing-lg);
	}

	.summary-stat {
		text-align: center;
		padding: var(--spacing-md);
		background: var(--background-tertiary);
		border-radius: var(--radius-md);
	}

	.stat-value {
		font-size: var(--font-size-2xl);
		font-weight: 700;
		color: var(--primary-color);
		margin-bottom: var(--spacing-xs);
	}

	.stat-label {
		font-size: var(--font-size-sm);
		color: var(--text-secondary);
		font-weight: 500;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.header-content {
			flex-direction: column;
			align-items: stretch;
		}
		
		.create-button {
			width: 100%;
		}

		.plans-grid {
			grid-template-columns: 1fr;
		}

		.plan-stats {
			grid-template-columns: 1fr;
		}

		.summary-stats {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.summary-stats {
			grid-template-columns: 1fr;
		}
	}
</style>

@code {
	private List<MembershipPlanDetailsDto>? membershipPlans;
	private bool isLoading = true;

	protected override async Task OnInitializedAsync()
	{
		await LoadMembershipPlans();
	}

	private async Task LoadMembershipPlans()
	{
		try
		{
			isLoading = true;
			StateHasChanged();

			membershipPlans = await _gymApiClient.GetMembershipPlansAsync();
			
			isLoading = false;
			StateHasChanged();
		}
		catch (Exception ex)
		{
			isLoading = false;
			StateHasChanged();
			// Handle error - could show snackbar
		}
	}

	private string GetPlanCardClass(MembershipPlanDetailsDto plan)
	{
		var classes = "plan-card hover-lift";
		if (IsPopularPlan(plan)) classes += " popular";
		if (IsPremiumPlan(plan)) classes += " premium";
		return classes;
	}

	private bool IsPopularPlan(MembershipPlanDetailsDto plan)
	{
		// Logic to determine if plan is popular (e.g., most subscribers)
		return plan.Price > 0 && plan.Price < 100; // Example logic
	}

	private bool IsPremiumPlan(MembershipPlanDetailsDto plan)
	{
		// Logic to determine if plan is premium
		return plan.Price >= 100; // Example logic
	}

	private string GetPlanIcon(MembershipPlanDetailsDto plan)
	{
		return plan.Price switch
		{
			0 => Icons.Material.Filled.StarBorder,
			< 50 => Icons.Material.Filled.FitnessCenter,
			< 100 => Icons.Material.Filled.Star,
			_ => Icons.Material.Filled.Diamond
		};
	}

	private string GetPeriodText(MembershipPeriod period)
	{
		return period switch
		{
			MembershipPeriod.Monthly => "month",
			MembershipPeriod.Quarterly => "quarter",
			MembershipPeriod.Yearly => "year",
			_ => "month"
		};
	}

	private string GetBillingText(MembershipPeriod period)
	{
		return period switch
		{
			MembershipPeriod.Monthly => "monthly",
			MembershipPeriod.Quarterly => "quarterly",
			MembershipPeriod.Yearly => "annually",
			_ => "monthly"
		};
	}

	private List<string> GetPlanFeatures(MembershipPlanDetailsDto plan)
	{
		var features = new List<string>();
		
		if (plan.Price == 0)
		{
			features.AddRange(new[]
			{
				"Basic gym access",
				"1 guest pass per month",
				"Standard equipment use",
				"Community support"
			});
		}
		else if (plan.Price < 50)
		{
			features.AddRange(new[]
			{
				"Full gym access",
				"Group fitness classes",
				"3 guest passes per month",
				"Locker room access",
				"Mobile app access"
			});
		}
		else if (plan.Price < 100)
		{
			features.AddRange(new[]
			{
				"Premium gym access",
				"Unlimited fitness classes",
				"Personal trainer consultation",
				"5 guest passes per month",
				"Premium locker access",
				"Nutrition guidance"
			});
		}
		else
		{
			features.AddRange(new[]
			{
				"VIP gym access",
				"Unlimited everything",
				"Personal trainer sessions",
				"Unlimited guest passes",
				"VIP locker room",
				"Meal planning service",
				"24/7 access",
				"Concierge service"
			});
		}

		return features;
	}

	private int GetSubscriberCount(MembershipPlanDetailsDto plan)
	{
		// Simulate subscriber count based on plan
		return new Random(plan.Id).Next(10, 500);
	}

	private decimal GetMonthlyRevenue(MembershipPlanDetailsDto plan)
	{
		var subscribers = GetSubscriberCount(plan);
		var monthlyPrice = plan.Period switch
		{
			MembershipPeriod.Yearly => plan.Price / 12,
			MembershipPeriod.Quarterly => plan.Price / 3,
			_ => plan.Price
		};
		return subscribers * monthlyPrice;
	}

	private int GetTotalSubscribers()
	{
		return membershipPlans?.Sum(p => GetSubscriberCount(p)) ?? 0;
	}

	private decimal GetTotalRevenue()
	{
		return membershipPlans?.Sum(p => GetMonthlyRevenue(p)) ?? 0;
	}

	private decimal GetAveragePrice()
	{
		if (membershipPlans == null || membershipPlans.Count == 0) return 0;
		return membershipPlans.Average(p => p.Price);
	}

	private Variant GetActionButtonVariant(MembershipPlanDetailsDto plan)
	{
		return IsPopularPlan(plan) ? Variant.Filled : Variant.Outlined;
	}

	private Color GetActionButtonColor(MembershipPlanDetailsDto plan)
	{
		return IsPopularPlan(plan) ? Color.Primary : Color.Secondary;
	}

	private string GetActionButtonText(MembershipPlanDetailsDto plan)
	{
		return plan.Price == 0 ? "Get Started Free" : "Choose Plan";
	}

	private void EditPlan(int planId)
	{
		_navigationManager.NavigateTo($"/membership-plan/{planId}/edit");
	}

	private void ViewSubscribers(int planId)
	{
		_navigationManager.NavigateTo($"/membership-plan/{planId}/subscribers");
	}

	private async Task DeletePlan(int planId)
	{
		var confirm = await _dialogService.ShowMessageBox(
			"Delete Membership Plan",
			"Are you sure you want to delete this membership plan? This action cannot be undone.",
			yesText: "Delete",
			cancelText: "Cancel"
		);

		if (confirm == true)
		{
			try
			{
				// Call delete API
				await LoadMembershipPlans(); // Refresh the list
			}
			catch (Exception ex)
			{
				// Handle error
			}
		}
	}

	private async Task OpenCreatePlanDialog()
	{
		var options = new DialogOptions 
		{ 
			MaxWidth = MaxWidth.Medium,
			CloseOnEscapeKey = true,
			CloseButton = true,
			DisableBackdropClick = false
		};
		
		var result = await _dialogService.ShowAsync<CreateMembershipPlanPopup>("Create New Membership Plan", options);

		if (result.Result == DialogResult.Ok())
		{
			await LoadMembershipPlans();
		}
	}
}
