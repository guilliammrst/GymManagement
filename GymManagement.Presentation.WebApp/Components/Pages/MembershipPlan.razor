            grid-template-columns: 1fr;
        }
        
        .info-grid {
            grid-template-columns: 1fr;
        }
        
        .club-info {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
    }
</style>

@code {
    [Parameter] public int PlanId { get; set; }
    
    private MembershipPlanDetailsDto? plan;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlan();
    }

    private async Task LoadPlan()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            plan = await GymApiClient.GetMembershipPlanByIdAsync(PlanId);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Erreur lors du chargement du plan: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task EditPlan()
    {
        if (plan != null)
        {
            await ModalService.ShowModal("update-membership-plan-modal", new { plan = plan });
        }
    }

    private async Task DeletePlan()
    {
        if (plan == null) return;

        var confirmed = await ModalService.ShowConfirmDialog(
            "Supprimer le plan d'abonnement",
            $"Êtes-vous sûr de vouloir supprimer le plan \"{plan.Name}\" ? Cette action est irréversible.",
            "Supprimer",
            "danger"
        );

        if (confirmed)
        {
            try
            {
                await NotificationService.ShowSuccess("Plan d'abonnement supprimé avec succès");
                Navigation.NavigateTo("/membership-plans");
            }
            catch (Exception ex)
            {
                await NotificationService.ShowError($"Erreur lors de la suppression: {ex.Message}");
            }
        }
    }

    private async Task CreateSimilarPlan()
    {
        if (plan != null)
        {
            await ModalService.ShowModal("create-membership-plan-modal", new { templatePlan = plan });
        }
    }

    private void ViewClub(int clubId)
    {
        Navigation.NavigateTo($"/clubs/{clubId}");
    }

    private void ViewAllPlans()
    {
        Navigation.NavigateTo("/membership-plans");
    }

    private string GetPlanCardClass(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "basic",
            MembershipPlanType.Premium => "premium",
            MembershipPlanType.VIP => "vip",
            _ => "basic"
        };
    }

    private string GetPlanTypeIcon(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "🥉",
            MembershipPlanType.Premium => "🥈",
            MembershipPlanType.VIP => "🥇",
            _ => "📋"
        };
    }

    private string GetPlanTypeDisplayName(MembershipPlanType type)
    {
        return type switch
        {
            MembershipPlanType.Basic => "Basique",
            MembershipPlanType.Premium => "Premium",
            MembershipPlanType.VIP => "VIP",
            _ => type.ToString()
        };
    }

    private string GetPeriodDisplayName(MembershipPeriod period)
    {
        return period switch
        {
            MembershipPeriod.Monthly => "mois",
            MembershipPeriod.Quarterly => "trimestre",
            MembershipPeriod.Yearly => "an",
            _ => period.ToString()
        };
    }

    private int GetDaysSinceCreation()
    {
        return plan != null ? (DateTime.Now - plan.CreatedAt).Days : 0;
    }

    private string GetMonthlyEquivalent()
    {
        if (plan == null) return "N/A";
        
        var monthlyPrice = plan.Period switch
        {
            MembershipPeriod.Monthly => plan.Price,
            MembershipPeriod.Quarterly => plan.Price / 3,
            MembershipPeriod.Yearly => plan.Price / 12,
            _ => plan.Price
        };
        
        return monthlyPrice.ToString("C");
    }

    private string GetPlanPopularity()
    {
        if (plan == null) return "N/A";
        
        // This would typically come from analytics data
        return plan.Type switch
        {
            MembershipPlanType.Basic => "⭐⭐⭐",
            MembershipPlanType.Premium => "⭐⭐⭐⭐",
            MembershipPlanType.VIP => "⭐⭐⭐⭐⭐",
            _ => "⭐⭐⭐"
        };
    }
    
    private void NavigateToMembershipPlans()
    {
        Navigation.NavigateTo("/membership-plans");
    }
} 