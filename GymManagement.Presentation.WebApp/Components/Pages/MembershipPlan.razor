@page "/membership-plans/{PlanId:int}"
@rendermode InteractiveServer
@using GymManagement.Application.Interfaces.Services.MembershipPlans
@using GymManagement.Presentation.WebApp.ApiClients.Gym
@using GymManagement.Presentation.WebApp.Services
@using GymManagement.Shared.Core.Enums
@inject GymAdminApiClient GymApiClient
@inject INotificationService NotificationService
@inject IModalService ModalService
@inject NavigationManager Navigation

<PageTitle>@(plan?.Name) - Plans d'Abonnement - GymManager</PageTitle>

<div class="page-container">
    @if (isLoading)
    {
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <p>Chargement des informations du plan...</p>
        </div>
    }
    else if (plan == null)
    {
        <div class="error-container">
            <div class="error-icon">❌</div>
            <h2>Plan d'abonnement non trouvé</h2>
            <p>Le plan d'abonnement demandé n'existe pas ou a été supprimé.</p>
            <button class="btn btn-primary" @onclick="NavigateToMembershipPlans">
                Retour à la liste
            </button>
        </div>
    }
    else
    {
        <!-- En-tête plan -->
        <div class="plan-header">
            <div class="breadcrumb">
                <a href="/membership-plans" class="breadcrumb-link">Plans d'Abonnement</a>
                <span class="breadcrumb-separator">›</span>
                <span class="breadcrumb-current">@plan.Name</span>
            </div>
            
            <div class="plan-hero @GetPlanCardClass(plan.Type)">
                <div class="plan-hero-content">
                    <div class="plan-type-badge">
                        @GetPlanTypeIcon(plan.Type)
                    </div>
                    
                    <div class="plan-hero-info">
                        <h1 class="plan-name">@plan.Name</h1>
                        <div class="plan-price">
                            <span class="price-amount">@plan.Price.ToString("C")</span>
                            <span class="price-period">/ @GetPeriodDisplayName(plan.Period)</span>
                        </div>
                        <div class="plan-badges">
                            <span class="badge badge-@GetPlanCardClass(plan.Type)">
                                @GetPlanTypeDisplayName(plan.Type)
                            </span>
                            <span class="badge badge-secondary">
                                @GetPeriodDisplayName(plan.Period)
                            </span>
                        </div>
                    </div>
                    
                    <div class="plan-hero-actions">
                        <button class="btn btn-outline btn-white" @onclick="EditPlan">
                            <span class="btn-icon">✏️</span>
                            Modifier
                        </button>
                        <button class="btn btn-danger btn-white" @onclick="DeletePlan">
                            <span class="btn-icon">🗑️</span>
                            Supprimer
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contenu principal -->
        <div class="plan-content">
            <div class="content-grid">
                <!-- Informations générales -->
                <div class="info-card">
                    <div class="card-header">
                        <h3>
                            <span class="card-icon">ℹ️</span>
                            Informations générales
                        </h3>
                    </div>
                    <div class="card-content">
                        <div class="info-grid">
                            <div class="info-item">
                                <label class="info-label">Nom du plan</label>
                                <span class="info-value">@plan.Name</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Prix</label>
                                <span class="info-value price-highlight">@plan.Price.ToString("C")</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Type</label>
                                <span class="info-value">@GetPlanTypeDisplayName(plan.Type)</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Période</label>
                                <span class="info-value">@GetPeriodDisplayName(plan.Period)</span>
                            </div>
                            <div class="info-item">
                                <label class="info-label">Date de création</label>
                                <span class="info-value">@plan.CreatedAt.ToString("dd/MM/yyyy à HH:mm")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Description -->
                <div class="info-card">
                    <div class="card-header">
                        <h3>
                            <span class="card-icon">📝</span>
                            Description
                        </h3>
                    </div>
                    <div class="card-content">
                        @if (!string.IsNullOrEmpty(plan.Description))
                        {
                            <div class="description-content">
                                <p>@plan.Description</p>
                            </div>
                        }
                        else
                        {
                            <div class="no-description">
                                <p>Aucune description disponible pour ce plan d'abonnement.</p>
                                <button class="btn btn-sm btn-outline" @onclick="EditPlan">
                                    <span class="btn-icon">➕</span>
                                    Ajouter une description
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Club associé -->
                @if (plan.Club != null)
                {
                    <div class="info-card">
                        <div class="card-header">
                            <h3>
                                <span class="card-icon">🏢</span>
                                Club associé
                            </h3>
                        </div>
                        <div class="card-content">
                            <div class="club-info">
                                <div class="club-details">
                                    <h4 class="club-name">@plan.Club.Name</h4>
                                    <p class="club-email">@plan.Club.Email</p>
                                    @if (!string.IsNullOrEmpty(plan.Club.PhoneNumber))
                                    {
                                        <p class="club-phone">📞 @plan.Club.PhoneNumber</p>
                                    }
                                </div>
                                <div class="club-actions">
                                    <button class="btn btn-sm btn-outline" @onclick="() => ViewClub(plan.Club.Id)">
                                        <span class="btn-icon">👁️</span>
                                        Voir le club
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Statistiques -->
                <div class="info-card">
                    <div class="card-header">
                        <h3>
                            <span class="card-icon">📊</span>
                            Statistiques
                        </h3>
                    </div>
                    <div class="card-content">
                        <div class="stats-grid">
                            <div class="stat-item">
                                <div class="stat-value">@GetDaysSinceCreation()</div>
                                <div class="stat-label">Jours depuis création</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">@GetMonthlyEquivalent()</div>
                                <div class="stat-label">Prix mensuel équivalent</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">@GetPlanPopularity()</div>
                                <div class="stat-label">Popularité</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions rapides -->
                <div class="info-card">
                    <div class="card-header">
                        <h3>
                            <span class="card-icon">⚡</span>
                            Actions rapides
                        </h3>
                    </div>
                    <div class="card-content">
                        <div class="quick-actions">
                            <button class="btn btn-primary" @onclick="CreateSimilarPlan">
                                <span class="btn-icon">📋</span>
                                Dupliquer ce plan
                            </button>
                            <button class="btn btn-outline" @onclick="EditPlan">
                                <span class="btn-icon">✏️</span>
                                Modifier le plan
                            </button>
                            <button class="btn btn-outline" @onclick="ViewAllPlans">
                                <span class="btn-icon">📋</span>
                                Voir tous les plans
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
