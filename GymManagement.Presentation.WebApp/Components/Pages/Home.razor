@page "/"
@layout PureLayout
@rendermode InteractiveServer
@inject AuthenticatedUser AuthenticatedUser

<div class="text-center mb-4">
    <h1 style="font-size: 3rem; font-weight: 700; color: var(--primary-color); margin-bottom: 1rem;">
        💪 GymManager
    </h1>
    <p style="font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;">
        Système de gestion moderne pour salles de sport - Interface Pure HTML/CSS/JS
    </p>
</div>

@if (!string.IsNullOrEmpty(AuthenticatedUser.Token))
{
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
        
        <!-- Utilisateurs -->
        <div class="card" style="cursor: pointer; transition: var(--transition);" onclick="location.href='/users'">
            <div class="card-body text-center">
                <div style="font-size: 3rem; margin-bottom: 1rem;">👥</div>
                <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">Utilisateurs</h3>
                <p style="color: var(--text-secondary);">Gérer les membres et le personnel</p>
            </div>
        </div>

        <!-- Clubs -->
        <div class="card" style="cursor: pointer; transition: var(--transition);" onclick="location.href='/clubs'">
            <div class="card-body text-center">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🏢</div>
                <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">Clubs</h3>
                <p style="color: var(--text-secondary);">Gérer les établissements</p>
            </div>
        </div>

        <!-- Abonnements -->
        <div class="card" style="cursor: pointer; transition: var(--transition);" onclick="location.href='/membership-plans'">
            <div class="card-body text-center">
                <div style="font-size: 3rem; margin-bottom: 1rem;">📋</div>
                <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">Abonnements</h3>
                <p style="color: var(--text-secondary);">Gérer les plans d'abonnement</p>
            </div>
        </div>

        <!-- Test du Système -->
        <div class="card" style="cursor: pointer; transition: var(--transition);" onclick="location.href='/test-pure-system'">
            <div class="card-body text-center">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🧪</div>
                <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">Test Système</h3>
                <p style="color: var(--text-secondary);">Tester les fonctionnalités</p>
            </div>
        </div>
    </div>

    <!-- Informations utilisateur -->
    <div class="card mt-4">
        <div class="card-header">
            <h3>Informations de session</h3>
        </div>
        <div class="card-body">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                <div>
                    <strong>Email:</strong> @AuthenticatedUser.Email
                </div>
                <div>
                    <strong>Rôle:</strong> @AuthenticatedUser.Role
                </div>
                <div>
                    <strong>Expiration:</strong> @AuthenticatedUser.TokenExpiration?.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center mt-4">
        <div class="card" style="max-width: 400px; margin: 0 auto;">
            <div class="card-body">
                <h3 style="color: var(--primary-color); margin-bottom: 1rem;">Connexion requise</h3>
                <p style="color: var(--text-secondary); margin-bottom: 2rem;">
                    Veuillez vous connecter pour accéder au système de gestion.
                </p>
                <a href="/login" class="btn btn-primary btn-lg">Se connecter</a>
            </div>
        </div>
    </div>
}

<style>
    .card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }
</style>
