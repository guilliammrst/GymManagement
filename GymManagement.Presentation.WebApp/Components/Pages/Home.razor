@page "/"
@rendermode InteractiveServer
@attribute [StreamRendering(true)]
@attribute [OutputCache(Duration = 60)]

<PageTitle>Dashboard - Gym Management</PageTitle>

<div class="dashboard-container animate-fade-in">
    <!-- Header Section -->
    <div class="dashboard-header">
        <MudText Typo="Typo.h3" GutterBottom="true">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="header-icon" />
            Dashboard
        </MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Welcome back! Here's what's happening at your gym today.
        </MudText>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <MudCard Class="stat-card hover-lift">
            <MudCardContent>
                <div class="stat-content">
                    <div class="stat-info">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@totalUsers</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Users</MudText>
                    </div>
                    <div class="stat-icon users">
                        <MudIcon Icon="@Icons.Material.Filled.People" />
                    </div>
                </div>
                <div class="stat-trend">
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                        +12% this month
                    </MudChip>
                </div>
            </MudCardContent>
        </MudCard>

        <MudCard Class="stat-card hover-lift">
            <MudCardContent>
                <div class="stat-content">
                    <div class="stat-info">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@totalClubs</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Active Clubs</MudText>
                    </div>
                    <div class="stat-icon clubs">
                        <MudIcon Icon="@Icons.Material.Filled.Business" />
                    </div>
                </div>
                <div class="stat-trend">
                    <MudChip T="string" Color="Color.Info" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingFlat" Size="Size.Small" />
                        Stable
                    </MudChip>
                </div>
            </MudCardContent>
        </MudCard>

        <MudCard Class="stat-card hover-lift">
            <MudCardContent>
                <div class="stat-content">
                    <div class="stat-info">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@totalMembershipPlans</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Membership Plans</MudText>
                    </div>
                    <div class="stat-icon plans">
                        <MudIcon Icon="@Icons.Material.Filled.CardMembership" />
                    </div>
                </div>
                <div class="stat-trend">
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                        +3 new plans
                    </MudChip>
                </div>
            </MudCardContent>
        </MudCard>

        <MudCard Class="stat-card hover-lift">
            <MudCardContent>
                <div class="stat-content">
                    <div class="stat-info">
                        <MudText Typo="Typo.h4" Color="Color.Primary">@todayAttendance</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Today's Attendance</MudText>
                    </div>
                    <div class="stat-icon attendance">
                        <MudIcon Icon="@Icons.Material.Filled.Today" />
                    </div>
                </div>
                <div class="stat-trend">
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                        +5% vs yesterday
                    </MudChip>
                </div>
            </MudCardContent>
        </MudCard>
    </div>

    <!-- Main Content Grid -->
    <div class="dashboard-content">
        <!-- Quick Actions -->
        <MudCard Class="quick-actions-card">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Quick Actions</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="quick-actions">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="@(() => _navigationManager.NavigateTo("/users"))"
                               Class="action-button">
                        Add New User
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Secondary" 
                               StartIcon="@Icons.Material.Filled.BusinessCenter"
                               OnClick="@(() => _navigationManager.NavigateTo("/clubs"))"
                               Class="action-button">
                        Manage Clubs
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Tertiary" 
                               StartIcon="@Icons.Material.Filled.CardGiftcard"
                               OnClick="@(() => _navigationManager.NavigateTo("/membership-plans"))"
                               Class="action-button">
                        Membership Plans
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Info" 
                               StartIcon="@Icons.Material.Filled.Assessment"
                               OnClick="@(() => _navigationManager.NavigateTo("/reports"))"
                               Class="action-button">
                        View Reports
                    </MudButton>
                </div>
            </MudCardContent>
        </MudCard>

        <!-- Recent Activity -->
        <MudCard Class="recent-activity-card">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Recent Activity</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="activity-icon success">
                            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" />
                        </div>
                        <div class="activity-content">
                            <MudText Typo="Typo.body2">New user registration</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">John Doe joined 2 hours ago</MudText>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon info">
                            <MudIcon Icon="@Icons.Material.Filled.Business" />
                        </div>
                        <div class="activity-content">
                            <MudText Typo="Typo.body2">Club updated</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Downtown Gym details modified</MudText>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="activity-icon warning">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" />
                        </div>
                        <div class="activity-content">
                            <MudText Typo="Typo.body2">Membership expiring</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">5 memberships expire this week</MudText>
                        </div>
                    </div>
                </div>
                <div class="activity-actions">
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.History">
                        View All Activity
                    </MudButton>
                </div>
            </MudCardContent>
        </MudCard>

        <!-- System Status -->
        <MudCard Class="system-status-card">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">System Status</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="status-items">
                    <div class="status-item">
                        <div class="status-indicator success"></div>
                        <div class="status-content">
                            <MudText Typo="Typo.body2">Database Connection</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Success">Healthy</MudText>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="status-indicator success"></div>
                        <div class="status-content">
                            <MudText Typo="Typo.body2">API Services</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Success">Running</MudText>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="status-indicator warning"></div>
                        <div class="status-content">
                            <MudText Typo="Typo.body2">Backup Status</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Warning">Pending</MudText>
                        </div>
                    </div>
                </div>
            </MudCardContent>
        </MudCard>
    </div>
</div>

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: var(--content-padding);
    }

    .dashboard-header {
        margin-bottom: var(--spacing-xl);
    }

    .header-icon {
        margin-right: var(--spacing-sm);
        color: var(--primary-color);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--spacing-lg);
        margin-bottom: var(--spacing-xl);
    }

    .stat-card {
        background: var(--background-card);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
        transition: all var(--transition-fast);
    }

    .stat-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-md);
    }

    .stat-info h4 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }

    .stat-icon.users { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .stat-icon.clubs { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .stat-icon.plans { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .stat-icon.attendance { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }

    .stat-trend {
        display: flex;
        justify-content: flex-end;
    }

    .dashboard-content {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: var(--spacing-lg);
    }

    .quick-actions-card {
        grid-column: 1 / 3;
    }

    .quick-actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);
    }

    .action-button {
        flex: 1;
        min-width: 150px;
    }

    .recent-activity-card {
        grid-column: 1 / 3;
    }

    .activity-list {
        margin-bottom: var(--spacing-lg);
    }

    .activity-item {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        padding: var(--spacing-md) 0;
        border-bottom: 1px solid var(--border-color);
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-icon {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 18px;
    }

    .activity-icon.success { background: var(--success-color); }
    .activity-icon.info { background: var(--info-color); }
    .activity-icon.warning { background: var(--warning-color); }

    .activity-content {
        flex: 1;
    }

    .activity-actions {
        display: flex;
        justify-content: center;
        padding-top: var(--spacing-md);
        border-top: 1px solid var(--border-color);
    }

    .system-status-card {
        grid-column: 3;
        grid-row: 1 / 3;
    }

    .status-items {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .status-item {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
    }

    .status-indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .status-indicator.success { background: var(--success-color); }
    .status-indicator.warning { background: var(--warning-color); }
    .status-indicator.error { background: var(--error-color); }

    .status-content {
        flex: 1;
    }

    /* Responsive Design */
    @media (max-width: 1024px) {
        .dashboard-content {
            grid-template-columns: 1fr 1fr;
        }
        
        .quick-actions-card {
            grid-column: 1 / -1;
        }
        
        .recent-activity-card {
            grid-column: 1 / -1;
        }
        
        .system-status-card {
            grid-column: 1 / -1;
            grid-row: auto;
        }
    }

    @media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
        
        .dashboard-content {
            grid-template-columns: 1fr;
        }
        
        .quick-actions {
            flex-direction: column;
        }
        
        .action-button {
            min-width: auto;
        }
    }
</style>

@code {
    private int totalUsers = 0;
    private int totalClubs = 0;
    private int totalMembershipPlans = 0;
    private int todayAttendance = 0;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            // Simulate loading data - replace with actual API calls
            await Task.Delay(1000);

            // Load users
            var users = await _gymApiClient.GetUsersAsync(new UserFilter
            {
                PageNumber = 1,
                PageSize = 1000
            });
            totalUsers = users?.Count ?? 0;

            // Load clubs
            var clubs = await _gymApiClient.GetClubsAsync();
            totalClubs = clubs?.Count ?? 0;

            // Load membership plans
            var membershipPlans = await _gymApiClient.GetMembershipPlansAsync();
            totalMembershipPlans = membershipPlans?.Count ?? 0;

            // Simulate today's attendance
            todayAttendance = new Random().Next(50, 200);

            isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Handle error
            isLoading = false;
            StateHasChanged();
        }
    }
}
