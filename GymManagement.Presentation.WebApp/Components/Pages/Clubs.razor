@page "/clubs"
@rendermode InteractiveServer
@attribute [StreamRendering(true)]
@attribute [OutputCache(Duration = 5)]

<PageTitle>Clubs Management - Gym Management</PageTitle>

<div class="clubs-container animate-fade-in">
	<!-- Header Section -->
	<div class="page-header">
		<div class="header-content">
			<div class="header-title">
				<MudText Typo="Typo.h4">
					<MudIcon Icon="@Icons.Material.Filled.Business" Class="header-icon" />
					Clubs Management
				</MudText>
				<MudText Typo="Typo.body1" Color="Color.Secondary">
					Manage and monitor all gym clubs and locations
				</MudText>
			</div>
			<div class="header-actions">
				<MudButton Variant="Variant.Filled"
						   Color="Color.Primary"
						   StartIcon="@Icons.Material.Filled.Add"
						   OnClick="OpenCreateClubDialog"
						   Class="create-button">
					Add New Club
				</MudButton>
			</div>
		</div>
	</div>

	<!-- Filters Section -->
	<MudCard Class="filters-card">
		<MudCardContent>
			<div class="filters-grid">
				<MudTextField @bind-Value="searchTerm"
							  Label="Search clubs..."
							  Variant="Variant.Outlined"
							  Adornment="Adornment.Start"
							  AdornmentIcon="@Icons.Material.Filled.Search"
							  AdornmentColor="Color.Primary"
							  Class="search-field"
							  Clearable="true" />
				
				<MudSelect @bind-Value="selectedFilter"
						   Label="Filter by"
						   Variant="Variant.Outlined"
						   Class="filter-select">
					<MudSelectItem Value="@("all")">All Clubs</MudSelectItem>
					<MudSelectItem Value="@("active")">Active Only</MudSelectItem>
					<MudSelectItem Value="@("inactive")">Inactive Only</MudSelectItem>
				</MudSelect>
				
				<div class="view-toggle">
					<MudToggleIconButton @bind-Toggled="@isGridView"
										Icon="@Icons.Material.Filled.ViewModule"
										ToggledIcon="@Icons.Material.Filled.ViewList"
										Color="Color.Primary"
										ToggledColor="Color.Primary"
										Title="Toggle View"
										ToggledTitle="Toggle View" />
				</div>
				
				<div class="filter-actions">
					<MudButton Variant="Variant.Filled"
							   Color="Color.Primary"
							   StartIcon="@Icons.Material.Filled.Search"
							   OnClick="OnSearch"
							   Class="search-button">
						Search
					</MudButton>
					<MudButton Variant="Variant.Outlined"
							   Color="Color.Secondary"
							   StartIcon="@Icons.Material.Filled.Refresh"
							   OnClick="OnReset"
							   Class="reset-button">
						Reset
					</MudButton>
				</div>
			</div>
		</MudCardContent>
	</MudCard>

	<!-- Content Section -->
	@if (isLoading)
	{
		<div class="loading-container">
			<MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
			<MudText Typo="Typo.body1" Color="Color.Secondary">Loading clubs...</MudText>
		</div>
	}
	else if (filteredClubs == null || filteredClubs.Count == 0)
	{
		<div class="empty-state">
			<MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Class="empty-icon" />
			<MudText Typo="Typo.h6" Color="Color.Secondary">No clubs found</MudText>
			<MudText Typo="Typo.body2" Color="Color.Secondary">
				Try adjusting your search criteria or add new clubs
			</MudText>
			<MudButton Variant="Variant.Filled"
					   Color="Color.Primary"
					   StartIcon="@Icons.Material.Filled.Add"
					   OnClick="OpenCreateClubDialog"
					   Class="empty-action-button">
				Add First Club
			</MudButton>
		</div>
	}
	else if (isGridView)
	{
		<!-- Grid View -->
		<div class="clubs-grid">
			@foreach (var club in filteredClubs)
			{
				<MudCard Class="club-card hover-lift clickable">
					<MudCardMedia Image="@GetClubImage(club)" Height="200" />
					<MudCardContent>
						<div class="club-header">
							<MudText Typo="Typo.h6" Class="club-name">@club.Name</MudText>
							<div class="club-status">
								<MudChip T="string" Color="@GetStatusColor(club)" Size="Size.Small">
									@GetStatusText(club)
								</MudChip>
							</div>
						</div>
						
						<div class="club-location">
							<MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
							<MudText Typo="Typo.body2" Color="Color.Secondary">
								@club.AddressDto?.Street, @club.AddressDto?.City
							</MudText>
						</div>
						
						<div class="club-stats">
							<div class="stat-item">
								<MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" />
								<MudText Typo="Typo.caption">@GetMemberCount(club) members</MudText>
							</div>
							<div class="stat-item">
								<MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Size="Size.Small" />
								<MudText Typo="Typo.caption">Premium</MudText>
							</div>
						</div>
						
						@if (!string.IsNullOrEmpty(club.Description))
						{
							<MudText Typo="Typo.body2" Color="Color.Secondary" Class="club-description">
								@(club.Description.Length > 100 ? club.Description.Substring(0, 100) + "..." : club.Description)
							</MudText>
						}
					</MudCardContent>
					
					<MudCardActions>
						<MudButton Variant="Variant.Text"
								   Color="Color.Primary"
								   StartIcon="@Icons.Material.Filled.Visibility"
								   OnClick="@(() => ViewClubDetails(club.Id))">
							View Details
						</MudButton>
						<MudSpacer />
						<MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default">
							<MudMenuItem OnClick="@(() => EditClub(club.Id))">
								<div class="menu-item-content">
									<MudIcon Icon="@Icons.Material.Filled.Edit" />
									<span>Edit</span>
								</div>
							</MudMenuItem>
							<MudMenuItem OnClick="@(() => DeleteClub(club.Id))">
								<div class="menu-item-content">
									<MudIcon Icon="@Icons.Material.Filled.Delete" />
									<span>Delete</span>
								</div>
							</MudMenuItem>
						</MudMenu>
					</MudCardActions>
				</MudCard>
			}
		</div>
	}
	else
	{
		<!-- List View -->
		<MudCard Class="table-card">
			<MudCardContent>
				<MudTable Items="@filteredClubs" 
						  Hover="true" 
						  Striped="true" 
						  Class="modern-table">
					<HeaderContent>
						<MudTh>
							<MudTableSortLabel SortBy="new Func<ClubDetailsDto, object>(x => x.Id)">
								ID
							</MudTableSortLabel>
						</MudTh>
						<MudTh>
							<MudTableSortLabel SortBy="new Func<ClubDetailsDto, object>(x => x.Name)">
								Name
							</MudTableSortLabel>
						</MudTh>
						<MudTh>Location</MudTh>
						<MudTh>Members</MudTh>
						<MudTh>Status</MudTh>
						<MudTh>Actions</MudTh>
					</HeaderContent>
					<RowTemplate>
						<MudTd DataLabel="ID">
							<MudChip T="string" Color="Color.Default" Size="Size.Small">
								@context.Id
							</MudChip>
						</MudTd>
						<MudTd DataLabel="Name">
							<div class="club-name-cell">
								<MudAvatar Image="@GetClubImage(context)" Size="Size.Small" />
								<span>@context.Name</span>
							</div>
						</MudTd>
						<MudTd DataLabel="Location">
							<div class="location-cell">
								<MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
								<span>@context.AddressDto?.City</span>
							</div>
						</MudTd>
						<MudTd DataLabel="Members">
							<MudText Typo="Typo.body2">@GetMemberCount(context)</MudText>
						</MudTd>
						<MudTd DataLabel="Status">
							<div class="club-status">
								<MudChip T="string" Color="@GetStatusColor(context)" Size="Size.Small">
									@GetStatusText(context)
								</MudChip>
							</div>
						</MudTd>
						<MudTd DataLabel="Actions">
							<div class="action-buttons">
								<MudTooltip Text="View Details">
									<MudIconButton Icon="@Icons.Material.Filled.Visibility"
												   Color="Color.Info"
												   Size="Size.Small"
												   OnClick="@(() => ViewClubDetails(context.Id))"
												   Class="action-button" />
								</MudTooltip>
								<MudTooltip Text="Edit Club">
									<MudIconButton Icon="@Icons.Material.Filled.Edit"
												   Color="Color.Primary"
												   Size="Size.Small"
												   OnClick="@(() => EditClub(context.Id))"
												   Class="action-button" />
								</MudTooltip>
								<MudTooltip Text="Delete Club">
									<MudIconButton Icon="@Icons.Material.Filled.Delete"
												   Color="Color.Error"
												   Size="Size.Small"
												   OnClick="@(() => DeleteClub(context.Id))"
												   Class="action-button" />
								</MudTooltip>
							</div>
						</MudTd>
					</RowTemplate>
				</MudTable>
			</MudCardContent>
		</MudCard>
	}
</div>

<style>
	.clubs-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--content-padding);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-lg);
	}

	.page-header {
		background: var(--background-card);
		border-radius: var(--radius-lg);
		padding: var(--spacing-lg);
		box-shadow: var(--shadow-sm);
		border: 1px solid var(--border-color);
	}

	.header-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-md);
	}

	.header-title {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xs);
	}

	.header-icon {
		margin-right: var(--spacing-sm);
		color: var(--primary-color);
	}

	.create-button {
		height: 40px;
		border-radius: var(--radius-lg);
		font-weight: 600;
	}

	.filters-card {
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
		box-shadow: var(--shadow-sm);
	}

	.filters-grid {
		display: grid;
		grid-template-columns: 2fr 1fr auto 1fr;
		gap: var(--spacing-md);
		align-items: end;
	}

	.view-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.filter-actions {
		display: flex;
		gap: var(--spacing-sm);
	}

	.search-button, .reset-button {
		height: 40px;
		border-radius: var(--radius-lg);
		font-weight: 600;
	}

	.loading-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-2xl);
		gap: var(--spacing-lg);
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
	}

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-2xl);
		gap: var(--spacing-lg);
		text-align: center;
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
	}

	.empty-icon {
		font-size: 4rem;
		color: var(--text-muted);
	}

	.empty-action-button {
		margin-top: var(--spacing-md);
		height: 44px;
		border-radius: var(--radius-lg);
		font-weight: 600;
	}

	.clubs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: var(--spacing-lg);
	}

	.club-card {
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
		transition: all var(--transition-fast);
		overflow: hidden;
	}

	.club-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--spacing-sm);
	}

	.club-name {
		font-weight: 600;
		color: var(--text-primary);
	}

	.club-location {
		display: flex;
		align-items: center;
		gap: var(--spacing-xs);
		margin-bottom: var(--spacing-md);
	}

	.club-stats {
		display: flex;
		gap: var(--spacing-lg);
		margin-bottom: var(--spacing-md);
	}

	.stat-item {
		display: flex;
		align-items: center;
		gap: var(--spacing-xs);
	}

	.club-description {
		margin-top: var(--spacing-md);
		line-height: 1.4;
	}

	.table-card {
		background: var(--background-card);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-color);
		box-shadow: var(--shadow-sm);
	}

	.modern-table {
		width: 100%;
	}

	.club-name-cell {
		display: flex;
		align-items: center;
		gap: var(--spacing-sm);
	}

	.location-cell {
		display: flex;
		align-items: center;
		gap: var(--spacing-xs);
	}

	.action-buttons {
		display: flex;
		gap: var(--spacing-xs);
	}

	.action-button {
		transition: all var(--transition-fast);
	}

	.action-button:hover {
		transform: scale(1.1);
	}

	.menu-item-content {
		display: flex;
		align-items: center;
		gap: var(--spacing-sm);
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.filters-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--spacing-md);
		}
		
		.search-field {
			grid-column: 1 / -1;
		}
		
		.view-toggle {
			grid-column: 1;
		}
		
		.filter-actions {
			grid-column: 2;
			justify-content: flex-end;
		}

		.clubs-grid {
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		}
	}

	@media (max-width: 768px) {
		.header-content {
			flex-direction: column;
			align-items: stretch;
		}
		
		.create-button {
			width: 100%;
		}
		
		.filters-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-md);
		}
		
		.view-toggle {
			justify-content: flex-start;
		}
		
		.filter-actions {
			flex-direction: column;
		}
		
		.search-button, .reset-button {
			width: 100%;
		}

		.clubs-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

@code {
	private List<ClubDetailsDto>? clubs;
	private List<ClubDetailsDto>? filteredClubs;
	private string searchTerm = string.Empty;
	private string selectedFilter = "all";
	private bool isGridView = true;
	private bool isLoading = true;

	protected override async Task OnInitializedAsync()
	{
		await LoadClubs();
	}

	private async Task LoadClubs()
	{
		try
		{
			isLoading = true;
			StateHasChanged();

		clubs = await _gymApiClient.GetClubsAsync();
			ApplyFilters();
			
			isLoading = false;
			StateHasChanged();
		}
		catch (Exception ex)
		{
			isLoading = false;
			StateHasChanged();
			// Handle error - could show snackbar
		}
	}

	private void ApplyFilters()
	{
		if (clubs == null)
		{
			filteredClubs = new List<ClubDetailsDto>();
			return;
		}

		filteredClubs = clubs.Where(club =>
		{
			// Search filter
			if (!string.IsNullOrEmpty(searchTerm))
			{
				var searchLower = searchTerm.ToLower();
				if (!club.Name.ToLower().Contains(searchLower) &&
					!(club.AddressDto?.City?.ToLower().Contains(searchLower) ?? false) &&
					!(club.Description?.ToLower().Contains(searchLower) ?? false))
				{
					return false;
				}
			}

			// Status filter
			if (selectedFilter != "all")
			{
				var isActive = true; // Simulate active status
				if (selectedFilter == "active" && !isActive) return false;
				if (selectedFilter == "inactive" && isActive) return false;
			}

			return true;
		}).ToList();
	}

	private async Task OnSearch()
	{
		ApplyFilters();
		StateHasChanged();
	}

	private async Task OnReset()
	{
		searchTerm = string.Empty;
		selectedFilter = "all";
		ApplyFilters();
		StateHasChanged();
	}

	private void ViewClubDetails(int clubId)
	{
		_navigationManager.NavigateTo($"/club/{clubId}");
	}

	private void EditClub(int clubId)
	{
		_navigationManager.NavigateTo($"/club/{clubId}/edit");
	}

	private async Task DeleteClub(int clubId)
	{
		var confirm = await _dialogService.ShowMessageBox(
			"Delete Club",
			"Are you sure you want to delete this club? This action cannot be undone.",
			yesText: "Delete",
			cancelText: "Cancel"
		);

		if (confirm == true)
		{
			try
			{
				// Call delete API
				await LoadClubs(); // Refresh the list
			}
			catch (Exception ex)
			{
				// Handle error
			}
		}
	}

	private async Task OpenCreateClubDialog()
	{
		var options = new DialogOptions 
		{ 
			MaxWidth = MaxWidth.Medium,
			CloseOnEscapeKey = true,
			CloseButton = true,
			DisableBackdropClick = false
		};
		
		var result = await _dialogService.ShowAsync<CreateClubPopup>("Create New Club", options);

		if (result.Result == DialogResult.Ok())
		{
			await LoadClubs();
		}
	}

	private string GetClubImage(ClubDetailsDto club)
	{
		// Return a placeholder or default image
		return $"https://picsum.photos/400/200?random={club.Id}";
	}

	private Color GetStatusColor(ClubDetailsDto club)
	{
		// Simulate status based on club data
		return Color.Success; // Default to active
	}

	private string GetStatusText(ClubDetailsDto club)
	{
		// Simulate status based on club data
		return "Active";
	}

	private int GetMemberCount(ClubDetailsDto club)
	{
		// Simulate member count
		return new Random(club.Id).Next(50, 500);
	}
}
