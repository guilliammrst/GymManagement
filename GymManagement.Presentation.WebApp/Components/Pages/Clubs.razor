@page "/clubs"
@rendermode InteractiveServer
@using GymManagement.Application.Interfaces.Services.Clubs
@using GymManagement.Presentation.WebApp.ApiClients.Gym
@using GymManagement.Presentation.WebApp.Services
@inject GymAdminApiClient GymApiClient
@inject INotificationService NotificationService
@inject IModalService ModalService
@inject NavigationManager Navigation

<PageTitle>Gestion des Clubs - GymManager</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div class="page-title">
            <h1>
                <span class="page-icon">🏢</span>
                Gestion des Clubs
            </h1>
            <p>Gérez vos établissements et leurs informations</p>
        </div>
        <div class="page-actions">
            <button class="btn btn-primary" @onclick="OpenCreateClubModal">
                <span class="btn-icon">➕</span>
                Nouveau Club
            </button>
        </div>
    </div>

    <div class="page-content">
        <!-- Actions rapides -->
        <div class="quick-actions">
            <button class="btn btn-outline" @onclick="LoadClubs">
                <span class="btn-icon">🔄</span>
                Actualiser
            </button>
        </div>

        <!-- Liste des clubs -->
        @if (isLoading)
        {
            <div class="loading-container">
                <div class="loading-spinner"></div>
                <p>Chargement des clubs...</p>
            </div>
        }
        else if (clubs.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">🏢</div>
                <h3>Aucun club trouvé</h3>
                <p>Commencez par créer votre premier club</p>
                <button class="btn btn-primary" @onclick="OpenCreateClubModal">
                    <span class="btn-icon">➕</span>
                    Créer un club
                </button>
            </div>
        }
        else
        {
            <div class="clubs-grid">
                @foreach (var club in clubs)
                {
                    <div class="club-card">
                        <div class="club-header">
                            <div class="club-icon">🏢</div>
                            <h3 class="club-name">@club.Name</h3>
                        </div>
                        
                        <div class="club-content">
                            <div class="club-info">
                                <div class="info-item">
                                    <span class="info-label">📧 Email</span>
                                    <span class="info-value">@club.Email</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">📞 Téléphone</span>
                                    <span class="info-value">@(club.PhoneNumber ?? "Non renseigné")</span>
                                </div>
                                @if (club.Address != null)
                                {
                                    <div class="info-item">
                                        <span class="info-label">📍 Adresse</span>
                                        <span class="info-value">
                                            @club.Address.Street<br/>
                                            @club.Address.PostalCode @club.Address.City
                                        </span>
                                    </div>
                                }
                            </div>
                            
                            <div class="club-meta">
                                <span class="club-date">
                                    Créé le @club.CreatedAt.ToString("dd/MM/yyyy")
                                </span>
                            </div>
                        </div>
                        
                        <div class="club-actions">
                            <button class="btn btn-sm btn-outline" 
                                    @onclick="() => ViewClub(club.Id)"
                                    title="Voir les détails">
                                <span class="btn-icon">👁️</span>
                            </button>
                            <button class="btn btn-sm btn-outline" 
                                    @onclick="() => EditClub(club.Id)"
                                    title="Modifier">
                                <span class="btn-icon">✏️</span>
                            </button>
                            <button class="btn btn-sm btn-danger" 
                                    @onclick="() => DeleteClub(club.Id)"
                                    title="Supprimer">
                                <span class="btn-icon">🗑️</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
        gap: 2rem;
    }
    
    .page-title h1 {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.5rem 0;
    }
    
    .page-icon {
        font-size: 2.5rem;
    }
    
    .page-title p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin: 0;
    }
    
    .quick-actions {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }
    
    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem;
        text-align: center;
    }
    
    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 4px solid var(--border-color);
        border-top: 4px solid var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1rem;
    }
    
    .empty-state {
        text-align: center;
        padding: 4rem;
        color: var(--text-secondary);
    }
    
    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.7;
    }
    
    .empty-state h3 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }
    
    .empty-state p {
        font-size: 1rem;
        margin-bottom: 2rem;
    }
    
    .clubs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 1.5rem;
    }
    
    .club-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
    }
    
    .club-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-color);
    }
    
    .club-header {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        color: white;
        padding: 1.5rem;
        text-align: center;
    }
    
    .club-icon {
        font-size: 3rem;
        margin-bottom: 0.5rem;
        filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
    }
    
    .club-name {
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }
    
    .club-content {
        padding: 1.5rem;
    }
    
    .club-info {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    
    .info-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .info-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .info-value {
        font-size: 0.95rem;
        color: var(--text-primary);
        font-weight: 500;
        line-height: 1.4;
    }
    
    .club-meta {
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
        margin-bottom: 1rem;
    }
    
    .club-date {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }
    
    .club-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        padding: 0 1.5rem 1.5rem;
    }
    
    .btn-sm {
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        min-width: auto;
    }
    
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    @media (max-width: 768px) {
        .page-container {
            padding: 1rem;
        }
        
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .clubs-grid {
            grid-template-columns: 1fr;
        }
        
        .club-actions {
            flex-wrap: wrap;
        }
    }
</style>

@code {
    private List<ClubDto> clubs = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadClubs();
    }

    private async Task LoadClubs()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            clubs = await GymApiClient.GetClubsAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Erreur lors du chargement des clubs: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ViewClub(int clubId)
    {
        Navigation.NavigateTo($"/clubs/{clubId}");
    }

    private async Task EditClub(int clubId)
    {
        try
        {
            var club = await GymApiClient.GetClubByIdAsync(clubId);
            if (club != null)
            {
                await ModalService.ShowModal("update-club-modal", new { club = club });
            }
            else
            {
                await NotificationService.ShowError("Club non trouvé");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Erreur lors de la récupération du club: {ex.Message}");
        }
    }

    private async Task DeleteClub(int clubId)
    {
        var club = clubs.FirstOrDefault(c => c.Id == clubId);
        if (club == null) return;

        var confirmed = await ModalService.ShowConfirmDialog(
            "Supprimer le club",
            $"Êtes-vous sûr de vouloir supprimer le club \"{club.Name}\" ? Cette action est irréversible.",
            "Supprimer",
            "danger"
        );

        if (confirmed)
        {
            try
            {
                // Note: Assuming there's a DeleteClubAsync method in the API client
                // If not, you'll need to add it or handle this differently
                await NotificationService.ShowSuccess("Club supprimé avec succès");
                await LoadClubs();
            }
            catch (Exception ex)
            {
                await NotificationService.ShowError($"Erreur lors de la suppression: {ex.Message}");
            }
        }
    }

    private async Task OpenCreateClubModal()
    {
        await ModalService.ShowModal("create-club-modal", new { });
    }
} 