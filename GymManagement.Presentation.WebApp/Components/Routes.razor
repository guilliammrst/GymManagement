<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthGuard>
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.PureLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </AuthGuard>
    </Found>
    <NotFound>
        <PageTitle>Page non trouvée</PageTitle>
        <LayoutView Layout="typeof(Layout.PureLayout)">
            <div class="not-found-container">
                <div class="not-found-content">
                    <div class="not-found-icon">🔍</div>
                    <h1>Page non trouvée</h1>
                    <p>La page que vous recherchez n'existe pas ou a été déplacée.</p>
                    <a href="/" class="btn btn-primary">Retour à l'accueil</a>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>

<style>
    .not-found-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        padding: 2rem;
    }
    
    .not-found-content {
        text-align: center;
        max-width: 500px;
    }
    
    .not-found-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.7;
    }
    
    .not-found-content h1 {
        font-size: 2rem;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }
    
    .not-found-content p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 2rem;
        line-height: 1.5;
    }
</style>